rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function adminPath() { return /databases/$(database)/documents/adminUsers/$(request.auth.uid); }
    function isSuperAdmin() {
      return signedIn()
        && exists(adminPath())
        && get(adminPath()).data.active == true
        && get(adminPath()).data.role == 'super_admin';
    }

    // Public storefront data. Server authority for writes is active super_admin only.
    match /products/{id} { allow read: if true; allow write: if isSuperAdmin(); }
    match /heroSlides/{id} { allow read: if true; allow write: if isSuperAdmin(); }
    match /siteSettings/{id} { allow read: if true; allow write: if isSuperAdmin(); }
    match /signatureShowcase/{id} { allow read: if true; allow write: if isSuperAdmin(); }
    match /categoryTiles/{id} { allow read: if true; allow write: if isSuperAdmin(); }
    match /brandTiles/{id} { allow read: if true; allow write: if isSuperAdmin(); }
    match /trustItems/{id} { allow read: if true; allow write: if isSuperAdmin(); }
    match /brands/{id} { allow read: if true; allow write: if isSuperAdmin(); }
    match /catalogs/{id} { allow read: if true; allow write: if isSuperAdmin(); }
    match /cars/{id} { allow read: if true; allow write: if isSuperAdmin(); }
    match /aboutPage/{id} { allow read: if true; allow write: if isSuperAdmin(); }
    match /contactPage/{id} { allow read: if true; allow write: if isSuperAdmin(); }

    match /orders/{id} { allow create: if true; allow read, update, delete: if isSuperAdmin(); }
    match /adminUsers/{uid} { allow read: if isSuperAdmin() || (signedIn() && request.auth.uid == uid); allow write: if isSuperAdmin(); }
    match /{document=**} { allow read, write: if false; }
  }
}
